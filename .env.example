# Mobile Check Deposit System - Environment Variables
APP_PORT=8080
VENDOR_STUB_PORT=8081
VENDOR_STUB_URL=http://localhost:8081
DB_PATH=./data/sqlite/mcd.db
IMAGE_STORAGE_PATH=./data/images
SETTLEMENT_OUTPUT_PATH=./reports/settlement
LOG_LEVEL=info
TIMEZONE=America/Chicago
EOD_CUTOFF_HOUR=18
EOD_CUTOFF_MINUTE=30
ENABLE_TEST_RESET=true
# Vision mode: set to "true" to use Claude Haiku for check image analysis
# instead of deterministic scenario responses. Requires ANTHROPIC_API_KEY.
VENDOR_VISION_MODE=false
ANTHROPIC_API_KEY=

# Security hardening (leave blank to disable auth — safe for local dev/tests)
# Set all three UI vars or none; mixing will break login.
API_KEY=
UI_USERNAME=
UI_PASSWORD=
SESSION_SECRET=
RATE_LIMIT_RPM=600
RETURN_FEE_CENTS=3000
